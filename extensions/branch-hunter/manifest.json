{
  "manifest_version": 3,
  "name": "Branch Hunter",
  "description": "Calculadora de payout para anuncios do Mercado Livre.",
  "version": "0.1.0",
  "action": {
    "default_title": "Branch Hunter"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.mercadolivre.com.br/*",
    "*://*.mercadolivre.com/*",
    "*://branchcommercehub.com/*",
    "*://branch-commerce.vercel.app/*",
    "*://localhost:3000/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.mercadolivre.com.br/*",
        "*://*.mercadolivre.com/*"
      ],
      "js": [
        "src/domain/types.js",
        "src/domain/hybrid-calculator.js",
        "src/ml-page-utils.js",
        "src/services/marketplace-dynamic-data.js",
        "src/storage.js",
        "src/content-script.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://branchcommercehub.com/*",
        "*://localhost:3000/*"
      ],
      "js": ["src/bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
